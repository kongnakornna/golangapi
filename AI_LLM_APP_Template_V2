    "github.com/gin-gonic/gin"
    "github.com/golang-jwt/jwt/v5"

    "github.com/yourusername/yourproject/pkg/errors"
    "github.com/yourusername/yourproject/pkg/utils"
)

func JWTAuth(secret string) gin.HandlerFunc {
    return func(c *gin.Context) {
        authHeader := c.GetHeader("Authorization")
        if authHeader == "" {
            c.AbortWithStatusJSON(http.StatusUnauthorized, errors.NewUnauthorizedError("missing authorization header"))
            return
        }

        parts := strings.Split(authHeader, " ")
        if len(parts) != 2 || strings.ToLower(parts[0]) != "bearer" {
            c.AbortWithStatusJSON(http.StatusUnauthorized, errors.NewUnauthorizedError("invalid authorization header format"))
            return
        }

        tokenStr := parts[1]
        claims, err := utils.ParseJWT(tokenStr, secret)
        if err != nil {
            c.AbortWithStatusJSON(http.StatusUnauthorized, errors.NewUnauthorizedError("invalid or expired token"))
            return
        }

        // Set user info in context
        c.Set("userID", claims.Subject)
        c.Set("userRoles", strings.Split(claims.Roles, ","))
        c.Next()
    }
}

func RequireRoles(allowedRoles ...string) gin.HandlerFunc {
    return func(c *gin.Context) {
        roles, exists := c.Get("userRoles")
        if !exists {
            c.AbortWithStatusJSON(http.StatusForbidden, errors.NewForbiddenError("access denied"))
            return
        }

        userRoles := roles.([]string)
        for _, role := range userRoles {
            for _, allowed := range allowedRoles {
                if role == allowed {
                    c.Next()
                    return
                }
            }
        }
        c.AbortWithStatusJSON(http.StatusForbidden, errors.NewForbiddenError("insufficient permissions"))
    }
}
